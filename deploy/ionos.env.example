# Copy this file to deploy/ionos.env and fill with your production values.
# The deploy script also accepts these values from environment variables.

IONOS_HOST=sftp.ionos.com
IONOS_USER=your_ionos_username
IONOS_PORT=22
IONOS_REMOTE_DIR=/htdocs
IONOS_LOCAL_DIR=out
# Optional: absolute path to SSH private key
# IONOS_IDENTITY_FILE=/home/jarvis/.ssh/id_rsa
